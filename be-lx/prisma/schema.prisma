// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  MEMBER
}

enum UserAccountStatus {
  UNVERIFIED
  PENDING
  ACTIVE
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED  
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ALUMNI
}

enum MealPeriod {
  morning
  afternoon
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  firstName String
  lastName  String
  role      Role     @default(MEMBER)
  accountStatus                 UserAccountStatus @default(UNVERIFIED)
  emailVerified                 Boolean   @default(false)
  emailVerifiedAt               DateTime?
  emailVerificationToken        String?   @unique
  emailVerificationTokenExpiresAt DateTime?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member          Member?
  posts           Post[]
  sportActivities SportActivity[]
  refreshTokens   RefreshToken[]
  mealSignUps     MealSignUp[]
  mealCookSignUps MealCookSignUp[]
  mealCookPermission MealCookPermission?

  @@map("users")
}

model MealCookPermission {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meal_cook_permissions")
}

model MealCookOpenWindow {
  id        String   @id @default(uuid())
  openedAt  DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([openedAt])
  @@map("meal_cook_open_windows")
}

model MealCookSignUp {
  id            String     @id @default(uuid())
  userId        String
  weekStartDate DateTime   @db.Date
  dayOfWeek     Int
  period        MealPeriod
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([weekStartDate, dayOfWeek, period])
  @@map("meal_cook_signups")
}

model MealSignUp {
  id            String     @id @default(uuid())
  userId        String
  weekStartDate DateTime   @db.Date
  dayOfWeek     Int
  period        MealPeriod
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate, dayOfWeek, period])
  @@index([userId, weekStartDate])
  @@map("meal_signups")
}

model RefreshToken {
  id               String    @id @default(uuid())
  userId           String
  tokenHash        String    @unique
  tokenJti         String    @unique
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  replacedByTokenId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model Member {
  id          String       @id @default(uuid())
  userId      String       @unique
  name        String?
  avatar      String?
  saintName   String?
  dateOfBirth DateTime?
  school      String?
  studentId   String?      @unique
  phoneNumber String?
  address     String?
  joinDate    DateTime     @default(now())
  status      MemberStatus @default(ACTIVE)
  bio         String?      @db.Text
  position    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts Post[]

  @@map("categories")
}

model Post {
  id         String     @id @default(uuid())
  title      String
  slug       String     @unique
  content    String     @db.Text
  location   String?
  eventTime  DateTime?
  excerpt    String?    @db.Text
  thumbnail  String?
  status     PostStatus @default(DRAFT)
  authorId   String
  categoryId String
  viewCount  Int        @default(0)
  isPinned   Boolean    @default(false)
  publishAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  author   User     @relation(fields: [authorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  images   Image[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@map("posts")
}

model Image {
  id          String   @id @default(uuid())
  url         String
  publicId    String
  postId      String?
  activityId  String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  post     Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  activity SportActivity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([activityId])
  @@map("images")
}

model SportActivity {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  location    String?
  startDate   DateTime
  endDate     DateTime?
  organizer   String?
  organizerId String
  thumbnail   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  organizerUser User    @relation(fields: [organizerId], references: [id])
  images        Image[]

  @@index([organizerId])
  @@map("sport_activities")
}
